<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>ひつじの弟子名簿</title>
</head>
<body>
  <h1>ひつじの弟子名簿</h1>
  <ul>
    <% users.forEach(user => { %>
      <li><%= user.name %> (ID: <%= user.id %>)</li>
    <% }) %>
  </ul>

  <h2>弟子入りする</h2>
  <form action="/users" method="post">
    <input type="text" name="name" placeholder="名前を入力" required>
    <button type="submit">弟子入り！</button>
  </form>
</body>
</html>
