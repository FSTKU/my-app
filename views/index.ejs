<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>ひつじの弟子名簿</title>
</head>
<body>
  <h1>ひつじの弟子名簿</h1>
   <ul>
    <% users.forEach(user => { %>
      <li><%= user.name %> (<%= user.age ? user.age + '歳' : '年齢未詳' %>)</li>
    <% }) %>
  </ul>

  <h2>弟子入りする</h2>
  <form action="/users" method="post">
    <input type="text" name="name" placeholder="名前" required>
    <input type="number" name="age" placeholder="年齢" required>
    <button type="submit">弟子入り！</button>
  </form>
</body>
</html>
